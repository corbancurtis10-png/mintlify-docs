  "keyFeatures": [
    "Simple animation playback with priority control",
    "Per-model animation track management",
    "Pause and resume animations via speed adjustment",
    "Animation event markers and stopped callbacks",
    "One-line ragdoll and unragdoll with optional duration",
    "Built-in TweenService and Vector3 lerp helpers",
    "Animation caching to reduce instance creation"
  ],
  "publicApiSurface": [
    "AnimationService.init(Options)",
    "AnimationService:play(model, id, type, looped?)",
    "AnimationService:stop(model, id?)",
    "AnimationService:pause(model, id)",
    "AnimationService:resume(model, id)",
    "AnimationService:getAnim(model, id)",
    "AnimationService:isPlaying(model, id)",
    "AnimationService:tween(instance, info, goal)",
    "AnimationService:lerp(instance, from, to, alpha)",
    "AnimationService:ragdoll(model, duration?)",
    "AnimationService:unragdoll(model)",
    "AnimationService:onMarker(model, id, markerName, callback)",
    "AnimationService:onStopped(model, id, callback)"
  ]
}
