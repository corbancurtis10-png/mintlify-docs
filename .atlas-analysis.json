{
  "projectType": "sdk-library",
  "projectName": "EZAnim",
  "projectDescription": "A lightweight Roblox Luau animation service module that simplifies playing, stopping, pausing, tweening, and ragdolling character animations.",
  "theme": "maple",
  "primaryColor": "#ef7025",
  "lightColor": "#eec9bc",
